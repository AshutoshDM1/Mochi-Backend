// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model url {
  id                  String    @id @default(uuid())
  url                 String
  cronId              String    @unique
  cron                cron      @relation(fields: [cronId], references: [id], onDelete: Cascade)
  
  status              String    @default("PENDING") // UP, DOWN, PENDING, ERROR
  
  totalUpTime         Int       @default(0) // in seconds
  totalDownTime       Int       @default(0) // in seconds
  averageResponseTime Float     @default(0) // in milliseconds
  totalChecks         Int       @default(0) // total number of checks performed
  
  lastCheckedAt       DateTime?
  lastStatus          String?   // Last check status for comparison
  
  logs                log[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model cron {
  id        String   @id @default(uuid())
  interval  String
  url       url?
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model log {
  id           String   @id @default(uuid())
  urlId        String
  url          url      @relation(fields: [urlId], references: [id], onDelete: Cascade)
  
  status       String   // UP, DOWN, ERROR
  statusCode   Int?     // HTTP status code (null if request failed)
  responseTime Int?     // in milliseconds (null if request failed)
  
  errorMessage String?  // Error message if request failed
  errorType    String?  // TIMEOUT, NETWORK_ERROR, DNS_ERROR, etc.
  
  headers      String?  // JSON string of response headers (optional)
  
  checkAt      DateTime @default(now()) // When the check was performed
  createdAt    DateTime @default(now())
  
  @@index([urlId, checkAt]) // Index for efficient querying
}

model User {
  id        String   @id // Clerk User ID
  username  String?  @unique // Clerk username (or email prefix)
  email     String   @unique
  crons     cron[]
  apiKeys   ApiKey[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id        String   @id @default(uuid())
  hash      String   @unique // SHA-256 hashed API key
  name      String   // Description/Name of the key (e.g. "Cursor IDE")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}