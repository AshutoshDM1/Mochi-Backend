    "/api/v1": {
      "get": {
        "summary": "Get API version information",
        "tags": ["General"],
        "responses": {
          "200": {
            "description": "API version information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Welcome to the Mochi api/v1"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
